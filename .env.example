# <resources>
# <resource name="app">
# <properties>
# <property name="host">
APP__HOST=0.0.0.0
# </property>
# <property name="port">
APP__PORT=3000
# </property>
# <property name="name">
APP__NAME=NestJS-MikroOrm-Template
# </property>
# <property name="version">
APP__VERSION=1.0.0
# </property>
# <property name="trustProxy">
APP__TRUST_PROXY=true
# </property>
# <property name="enableGloablPrefix">
APP__ENABLE_GLOBAL_PREFIX=true
# </property>
# <property name="globalPrefix">
APP__GLOBAL_PREFIX=api
# </property>
# <property name="enableVersion">
APP__ENABLE_VERSION=true
# </property>
# <property name="corsOrigin">
# Comma-separated allowed origins, or "*" for any. Lock this down in production.
APP__CORS_ORIGIN=*
# </property>
# <property name="corsCredentials">
APP__CORS_CREDENTIALS=false
# </property>
# </properties>
# </resource>
# <resource name="database">
# <properties>
# <property name="host">
DATABASE__HOST=0.0.0.0
# </property>
# <property name="port">
DATABASE__PORT=5432
# </property>
# <property name="username">
DATABASE__USERNAME=postgres
# </property>
# <property name="password">
DATABASE__PASSWORD=secret
# </property>
# <property name="name">
DATABASE__NAME=example
# </property>
# <property name="schema">
DATABASE__SCHEMA=public
# </property>
# </properties>
# </resource>
# <resource name="throttler">
# <properties>
# <property name="ttl">
# Time window in milliseconds.
THROTTLER__TTL=60000
# </property>
# <property name="limit">
# Max requests per window per client.
THROTTLER__LIMIT=100
# </property>
# </properties>
# </resource>
# <resource name="log">
# <properties>
# <property name="level">
LOG__LEVEL=info
# </property>
# <property name="enable">
LOG__ENABLE=true
# </property>
# </properties>
# </resource>
# <resource name="node">
# <properties>
# <property name="env">
NODE_ENV=development
# </property>
# </properties>
# </resource>
# <resource name="redis">
# <properties>
# <property name="url">
REDIS__URL=redis://localhost:6379
# </property>
# </properties>
# </resource>
# <resource name="security">
# <properties>
# <property name="hash">
SECURITY__HASH=argon2
# </property>
# </properties>
# </resource>
# <resource name="swagger">
# <properties>
# <property name="enable">
SWAGGER__ENABLE=false
# </property>
# <property name="path">
SWAGGER__PATH=docs
# </property>
# </properties>
# </resource>
# <resource name="s3">
# <properties>
# <property name="region">
S3__REGION=us-east-1
# </property>
# <property name="endpoint">
S3__ENDPOINT=
# </property>
# <property name="accessKeyId">
S3__ACCESS_KEY_ID=
# </property>
# <property name="secretAccessKey">
S3__SECRET_ACCESS_KEY=
# </property>
# <property name="bucket">
S3__BUCKET=
# </property>
# <property name="forcePathStyle">
S3__FORCE_PATH_STYLE=false
# </property>
# <property name="uploadUrlTtlSeconds">
S3__UPLOAD_URL_TTL_SECONDS=900
# </property>
# <property name="downloadUrlTtlSeconds">
S3__DOWNLOAD_URL_TTL_SECONDS=900
# </property>
# <property name="maxUploadSizeBytes">
S3__MAX_UPLOAD_SIZE_BYTES=52428800
# </property>
# <property name="keyPrefix">
S3__KEY_PREFIX=uploads
# </property>
# </properties>
# </resource>
# <resource name="auth">
# <properties>
# <property name="jwtAccessSecret">
AUTH__JWT_ACCESS_SECRET=change-me-access
# </property>
# <property name="jwtRefreshSecret">
AUTH__JWT_REFRESH_SECRET=change-me-refresh
# </property>
# <property name="jwtAccessTtlSeconds">
AUTH__JWT_ACCESS_TTL_SECONDS=900
# </property>
# <property name="jwtRefreshTtlSeconds">
AUTH__JWT_REFRESH_TTL_SECONDS=2592000
# </property>
# <property name="jwtIssuer">
AUTH__JWT_ISSUER=nestjs-mikroorm-template
# </property>
# <property name="jwtAudience">
AUTH__JWT_AUDIENCE=nestjs-mikroorm-template
# </property>
# <property name="otpLength">
AUTH__OTP_LENGTH=6
# </property>
# <property name="otpTtlSeconds">
AUTH__OTP_TTL_SECONDS=300
# </property>
# <property name="otpResendIntervalSeconds">
AUTH__OTP_RESEND_INTERVAL_SECONDS=60
# </property>
# <property name="otpMaxAttempts">
AUTH__OTP_MAX_ATTEMPTS=5
# </property>
# </properties>
