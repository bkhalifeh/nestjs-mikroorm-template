import {
  List{{pascalCase name}}QueryDto,
  LIST_{{constantCase name}}_SEARCHABLE_FIELDS,
} from '../dto/list-{{kebabCase name}}.dto';
// </import>
{{/if}}
// <import name="{{pascalCase name}}Repository">
import { {{pascalCase name}}Repository } from '../repositories/{{kebabCase name}}.repository';
// </import>
// <import name="{{pascalCase name}}">
import { {{pascalCase name}} } from '../domains/{{kebabCase name}}';
// </import>
// </imports>

@Injectable()
export class {{pascalCase name}}Service {
  constructor(
    // <properties>
    // <property name="logger">
    @InjectPinoLogger({{pascalCase name}}Service.name)
    private readonly logger: PinoLogger,
    // </property>
    // <property name="clsService">
    private readonly clsService: ClsService,
    // </property>
    // <property name="em">
    private readonly em: EntityManager,
    // </property>
    // <property name="{{camelCase name}}Repository">
    private readonly {{camelCase name}}Repository: {{pascalCase name}}Repository,
    // </property>
    // </properties>
  ) {}

  {{#if genCRUD}}
  // <functions>
  // <function name="create">
  async create(create{{pascalCase name}}Dto: Create{{pascalCase name}}Dto): Promise<{{pascalCase name}}> {
    const requestId = this.clsService.get<string>('requestId');
    this.logger.info({ requestId, create{{pascalCase name}}Dto }, 'Creating {{camelCase name}}');

    const {{camelCase name}} = this.{{camelCase name}}Repository.create(create{{pascalCase name}}Dto);
    await this.em.flush();

    this.logger.info({ requestId, id: {{camelCase name}}.id }, '{{pascalCase name}} created successfully');
    return {{camelCase name}};
  }
  // </function>

  // <function name="findAll">
  {{#if enablePagination}}
  async findAll(query: List{{pascalCase name}}QueryDto): Promise<[{{pascalCase name}}[], number]> {
    const requestId = this.clsService.get<string>('requestId');
    this.logger.info({ requestId, query }, 'Fetching {{camelCase name}}s');

    const where = this.build{{pascalCase name}}Where(query);
    const orderBy = query.order ?? { id: 'ASC' };

    const total = await this.{{camelCase name}}Repository.count(where);
    const lastPage = Math.max(1, Math.ceil(total / query.perPage));

    if (query.page > lastPage) {
      this.logger.warn(
        { requestId, page: query.page, lastPage },
        '{{pascalCase name}}s page out of range',
      );
      throw new BadRequestException(
        `Page ${query.page} is out of range; last page is ${lastPage}`,
      );
    }

    if (total === 0) {
      this.logger.info({ requestId, total: 0 }, 'No {{camelCase name}}s to fetch');
      return [[], 0];
    }

    const offset = (query.page - 1) * query.perPage;
    const {{camelCase name}}s = await this.{{camelCase name}}Repository.find(where, {
      offset,
      limit: query.perPage,
      orderBy,
    });

    this.logger.info({ requestId, count: {{camelCase name}}s.length, total }, '{{pascalCase name}}s fetched successfully');
    return [{{camelCase name}}s, total];
  }
  {{else}}
  async findAll(query: List{{pascalCase name}}QueryDto): Promise<{{pascalCase name}}[]> {
    const requestId = this.clsService.get<string>('requestId');
    this.logger.info({ requestId, query }, 'Fetching all {{camelCase name}}s');

    const where = this.build{{pascalCase name}}Where(query);
    const orderBy = query.order ?? { id: 'ASC' };

    const {{camelCase name}}s = await this.{{camelCase name}}Repository.find(where, { orderBy });

    this.logger.info({ requestId, count: {{camelCase name}}s.length }, '{{pascalCase name}}s fetched successfully');
    return {{camelCase name}}s;
  }
  {{/if}}

  private build{{pascalCase name}}Where(
    query: List{{pascalCase name}}QueryDto,
  ): FilterQuery<{{pascalCase name}}> {
    const where: Record<string, unknown> = {};

    // <filters>
    // </filters>

    if (query.search && LIST_{{constantCase name}}_SEARCHABLE_FIELDS.length > 0) {
      const term = `%${query.search}%`;
      const $or: Record<string, unknown>[] = [];
      // <search-fields>
      // </search-fields>
      if ($or.length > 0) {
        where['$or'] = $or;
      }
    }

    return where as FilterQuery<{{pascalCase name}}>;
  }
  // </function>

  // <function name="findOne">
  async findOne(id: string): Promise<{{pascalCase name}}> {
    const requestId = this.clsService.get<string>('requestId');
    this.logger.info({ requestId, id }, 'Fetching {{camelCase name}} by id');

    const {{camelCase name}} = await this.{{camelCase name}}Repository.findOne({ id });

    if (!{{camelCase name}}) {
      this.logger.warn({ requestId, id }, '{{pascalCase name}} not found');
      throw new NotFoundException(`{{pascalCase name}} with id ${id} not found`);
    }

    this.logger.info({ requestId, id }, '{{pascalCase name}} fetched successfully');
    return {{camelCase name}};
  }
  // </function>

  // <function name="update">
  async update(id: string, update{{pascalCase name}}Dto: Update{{pascalCase name}}Dto): Promise<{{pascalCase name}}> {
    const requestId = this.clsService.get<string>('requestId');
    this.logger.info({ requestId, id, update{{pascalCase name}}Dto }, 'Updating {{camelCase name}}');

    const {{camelCase name}} = await this.findOne(id);
    this.{{camelCase name}}Repository.assign({{camelCase name}}, update{{pascalCase name}}Dto);
    await this.em.flush();

    this.logger.info({ requestId, id }, '{{pascalCase name}} updated successfully');
    return {{camelCase name}};
  }
  // </function>

  // <function name="remove">
  async remove(id: string): Promise<void> {
    const requestId = this.clsService.get<string>('requestId');
    this.logger.info({ requestId, id }, 'Removing {{camelCase name}}');

    const {{camelCase name}} = await this.findOne(id);
    this.em.remove({{camelCase name}});
    await this.em.flush();
    this.logger.info({ requestId, id }, '{{pascalCase name}} removed successfully');
  }
  // </function>

  // </functions>
  {{/if}}
}
