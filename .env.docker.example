# Production compose env — copy to `.env` and fill in real secrets:
#   cp .env.docker.example .env
#
# Note: docker-compose.prod.yml pins DATABASE__HOST/PORT and REDIS__URL to the
# compose service hostnames, so you do not need to set those here.

# ── App ──────────────────────────────────────────────────────────
APP__NAME=NestJS-MikroOrm-Template
APP__VERSION=1.0.0
APP__CORS_ORIGIN=https://your-frontend.example.com
APP__CORS_CREDENTIALS=true

# ── Database (used by both postgres service and the app) ─────────
DATABASE__USERNAME=postgres
DATABASE__PASSWORD=change-me-strong-password
DATABASE__NAME=example
DATABASE__SCHEMA=public

# ── Auth (REQUIRED — generate long random strings) ───────────────
AUTH__JWT_ACCESS_SECRET=change-me-access-secret
AUTH__JWT_REFRESH_SECRET=change-me-refresh-secret
AUTH__JWT_ACCESS_TTL_SECONDS=900
AUTH__JWT_REFRESH_TTL_SECONDS=2592000

# ── Throttler ────────────────────────────────────────────────────
THROTTLER__TTL=60000
THROTTLER__LIMIT=100

# ── Security ─────────────────────────────────────────────────────
SECURITY__HASH=argon2

# ── S3 / object storage (REQUIRED: access key, secret, bucket) ───
S3__REGION=us-east-1
S3__ENDPOINT=
S3__FORCE_PATH_STYLE=false
S3__ACCESS_KEY_ID=change-me
S3__SECRET_ACCESS_KEY=change-me
S3__BUCKET=app-bucket

# ── Mail (set transport=smtp + real host for production email) ───
MAIL__TRANSPORT=smtp
MAIL__HOST=smtp.example.com
MAIL__PORT=587
MAIL__SECURE=false
MAIL__USERNAME=
MAIL__PASSWORD=
MAIL__FROM=no-reply@example.com

# ── SMS (log | twilio) ───────────────────────────────────────────
SMS__PROVIDER=log
SMS__TWILIO_ACCOUNT_SID=
SMS__TWILIO_AUTH_TOKEN=
SMS__TWILIO_FROM=

# ── OAuth (optional; leave non-empty placeholders if unused) ─────
OAUTH__GOOGLE_CLIENT_ID=
OAUTH__GOOGLE_CLIENT_SECRET=
OAUTH__GITHUB_CLIENT_ID=
OAUTH__GITHUB_CLIENT_SECRET=
